#include<stdio.h>
#include<stdlib.h>
struct lnode{
    int data;
    struct lnode*next;
};
typedef struct lnode node;
node*head=NULL;
void insertatbegin(int val){
    node*newnode=(node*)malloc(sizeof(node));
    if(newnode==NULL){
        printf("empty");
        return;
    }
    newnode->data=val;
    if(head==NULL){
        newnode->next=head;
        head=newnode;
    }
    else{
        newnode->next=head;
        head=newnode;
    }
    printf("insert at %d begin\n",val);
}

void Display(){
     if(head==NULL){
        printf("empty");
        return;
     }
      node*temp=head;
     while(temp!=NULL){
         printf("%d",temp->data);
         temp=temp->next;
     }
}
int main(){
    int val;
    int choice;
    
    while(1){
        printf("1.insertatbegin:\n");
        printf("2.Display:\n");
        scanf("%d",&choice);
    
    switch(choice){
        case 1:
        printf("insertatbegin\n");
        scanf("%d",&val);
        insertatbegin(val);
        break;
        case 2:
        printf("Display\n");
        Display();
        break;
        case 3:
        exit(0);
        break;
        default:printf("Invalid number:");
    }
    }
    return 0;
}
